  } catch {
    log(11, "Note: Could not copy ADB keys (may not exist yet).");
  }
}

async function step12() {
  log(12, "Disabling phantom process killer...");
  const cmds = [
    "adb shell /system/bin/device_config set_sync_disabled_for_tests persistent",
    "adb shell /system/bin/device_config put activity_manager max_phantom_processes 2147483647",
    "adb shell settings put global settings_enable_monitor_phantom_procs false",
  ];
  for (const cmd of cmds) {
    try {
      await runTermux(12, cmd);
    } catch (e) {
      log(12, `Warning: ${cmd} failed (${e.message})`);
    }
  }
  log(12, "Opening battery optimization settings...");
  try {
    await runTermux(12, "adb shell am start -a android.settings.IGNORE_BATTERY_OPTIMIZATION_SETTINGS");
  } catch {
    log(12, "Could not open battery settings (ADB may not be connected).");
