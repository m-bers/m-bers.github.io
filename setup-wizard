let running = false;

async function runAutoSteps(startFrom) {
  if (running) return;
  running = true;

  for (let i = startFrom; i <= STEPS.length; i++) {
    const step = STEPS.find(s => s.id === i);
    if (!step) continue;
    if (state[i].status === "done") continue;

    currentStep = i;

    // Interactive steps — pause and wait for user action
    if (!step.auto) {
      setStatus(i, "waiting");
      running = false;
      return;
    }

    setStatus(i, "running");
    try {
      switch (i) {
        case 1: await step1(); break;
        case 2: await step2(); break;
        case 3: await step3(); break;
        case 4: await step4(); break;
        case 5: await step5(); break;
        case 7: await step7(); break;
        case 8: await step8(); break;
        case 9: await step9(); break;
        case 10: await step10(); break;
        case 12: await step12(); break;
        case 13: await step13(); break;
        case 14: await step14(); break;
      }
      setStatus(i, "done");
    } catch (e) {
      log(i, `ERROR: ${e.message}`);
      setStatus(i, "error");
      running = false;
      return;
    }
  }
  running = false;
}

