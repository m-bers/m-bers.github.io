// ---------------------------------------------------------------------------
// HTTP server
// ---------------------------------------------------------------------------
function parseBody(req) {
  return new Promise((resolve) => {
    let body = "";
    req.on("data", c => body += c);
    req.on("end", () => {
      try { resolve(JSON.parse(body)); } catch { resolve({}); }
    });
  });
}

const server = http.createServer(async (req, res) => {
  const url = req.url.split("?")[0];

  // SSE endpoint
  if (url === "/events" && req.method === "GET") {
    res.writeHead(200, {
      "Content-Type": "text/event-stream",
      "Cache-Control": "no-cache",
      "Connection": "keep-alive",
      "Access-Control-Allow-Origin": "*",
    });
    res.write(":\n\n");
    sseClients.add(res);
    req.on("close", () => sseClients.delete(res));

    // Send current state
    for (const [id, s] of Object.entries(state)) {
      res.write(`data: ${JSON.stringify({ step: parseInt(id), status: s.status, log: "" })}\n\n`);
    }
    return;
  }

  // API endpoints
  if (url === "/api/start" && req.method === "POST") {
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    runAutoSteps(1);
    return;
  }

  if (url === "/api/claude-login" && req.method === "POST") {
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    setStatus(6, "running");
    try {
      await step6start();
      const credPath = `${ROOTFS}/root/.claude/.credentials.json`;
      if (fs.existsSync(credPath)) {
        setStatus(6, "done");
        runAutoSteps(7);
      } else {
        log(6, "Login may not have completed. Check credentials.");
        setStatus(6, "error");
      }
    } catch (e) {
      log(6, `ERROR: ${e.message}`);
      setStatus(6, "error");
    }
    return;
  }

  if (url === "/api/adb-pair" && req.method === "POST") {
    const body = await parseBody(req);
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    try {
      await step11pair(body.ip, body.port, body.code);
    } catch (e) {
      log(11, `Pair error: ${e.message}`);
    }
    return;
  }

  if (url === "/api/adb-connect" && req.method === "POST") {
    const body = await parseBody(req);
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    try {
      await step11connect(body.ip, body.port);
      setStatus(11, "done");
    } catch (e) {
      log(11, `Connect error: ${e.message}`);
      setStatus(11, "error");
    }
    return;
  }

  if (url === "/api/continue" && req.method === "POST") {
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    // Find next pending step after last done interactive step
    const nextStep = STEPS.find(s => state[s.id].status === "pending" || state[s.id].status === "waiting");
    if (nextStep) runAutoSteps(nextStep.id);
    return;
  }

  if (url === "/api/retry" && req.method === "POST") {
    const body = await parseBody(req);
    const stepId = body.step;
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    if (stepId) {
      state[stepId].status = "pending";
      state[stepId].log = [];
      runAutoSteps(stepId);
    }
    return;
  }

  if (url === "/api/skip-adb" && req.method === "POST") {
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end('{"ok":true}');
    setStatus(11, "done");
    log(11, "ADB setup skipped.");
    runAutoSteps(12);
    return;
  }

  if (url === "/api/state" && req.method === "GET") {
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end(JSON.stringify({ state, currentStep }));
    return;
  }

  // Default: serve HTML
  res.writeHead(200, { "Content-Type": "text/html" });
  res.end(HTML);
});

