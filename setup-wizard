#!/bin/bash
# Setup Wizard — serves a web UI on port 8888 that orchestrates the full install.
# Runs in Termux (not inside proot). Creates a Node.js server via heredoc.

set -e

WIZARD_PORT=8888
WIZARD_DIR="/tmp/setup-wizard-app"
PREFIX="/data/data/com.termux/files/usr"
TERMUX_HOME="/data/data/com.termux/files/home"
ROOTFS="$PREFIX/var/lib/proot-distro/installed-rootfs/ubuntu"

mkdir -p "$WIZARD_DIR"

cat > "$WIZARD_DIR/server.mjs" <<'SERVERJS'
import http from "http";
import { execSync, spawn } from "child_process";
import fs from "fs";
import path from "path";

const PORT = 8888;
const PREFIX = "/data/data/com.termux/files/usr";
const TERMUX_HOME = "/data/data/com.termux/files/home";
const ROOTFS = `${PREFIX}/var/lib/proot-distro/installed-rootfs/ubuntu`;
const GITHUB_USER = "m-bers";
const GITHUB_REPO = "m-bers/m-bers.github.io";
const MOBVIBE_EMAIL = "admin@mobvibe.local";
const MOBVIBE_PASS = "admin123";

// ---------------------------------------------------------------------------
// SSE clients
// ---------------------------------------------------------------------------
const sseClients = new Set();
function broadcast(data) {
  const msg = `data: ${JSON.stringify(data)}\n\n`;
  for (const res of sseClients) {
    try { res.write(msg); } catch {}
  }
}

// ---------------------------------------------------------------------------
// Step state
// ---------------------------------------------------------------------------
const STEPS = [
  { id: 1,  name: "Acquire Wakelock",           auto: true,  context: "termux" },
  { id: 2,  name: "Install Termux Packages",    auto: true,  context: "termux" },
  { id: 3,  name: "Install Ubuntu",             auto: true,  context: "termux" },
  { id: 4,  name: "Install Node.js (proot)",    auto: true,  context: "proot" },
  { id: 5,  name: "Install Claude Code",        auto: true,  context: "proot" },
  { id: 6,  name: "Claude Code Login",          auto: false, context: "proot" },
  { id: 7,  name: "Install Dev Tools",          auto: true,  context: "proot" },
  { id: 8,  name: "Install Mobvibe",            auto: true,  context: "proot" },
  { id: 9,  name: "Start Services",             auto: true,  context: "termux" },
  { id: 10, name: "Create User & E2EE Setup",   auto: true,  context: "proot" },
  { id: 11, name: "ADB Wireless Debugging",     auto: false, context: "termux" },
  { id: 12, name: "Phantom Killer & Battery",   auto: true,  context: "termux" },
  { id: 13, name: "Verify E2EE",                auto: true,  context: "termux" },
  { id: 14, name: "Complete",                   auto: true,  context: "termux" },
];

const state = {};
for (const s of STEPS) {
  state[s.id] = { status: "pending", log: [] };
}
let currentStep = 0;

function log(step, line) {
  const s = state[step];
  if (!s) return;
  s.log.push(line);
  if (s.log.length > 200) s.log.shift();
  broadcast({ step, status: s.status, log: line });
}

function setStatus(step, status) {
  state[step].status = status;
  broadcast({ step, status, log: "" });
}

// ---------------------------------------------------------------------------
// Command helpers
// ---------------------------------------------------------------------------
function termuxEnv() {
  return { ...process.env, PREFIX, HOME: TERMUX_HOME, PATH: `${PREFIX}/bin:${PREFIX}/sbin:${process.env.PATH}` };
}

function runTermux(step, cmd) {
  return new Promise((resolve, reject) => {
    const child = spawn("bash", ["-c", cmd], { env: termuxEnv() });
    child.stdout.on("data", d => d.toString().split("\n").forEach(l => { if (l) log(step, l); }));
    child.stderr.on("data", d => d.toString().split("\n").forEach(l => { if (l) log(step, l); }));
    child.on("close", code => code === 0 ? resolve() : reject(new Error(`Exit code ${code}`)));
  });
}

function runProot(step, cmd) {
  const wrapped = `proot-distro login ubuntu -- bash -lc '${cmd.replace(/'/g, "'\\''")}'`;
  return runTermux(step, wrapped);
}

function runProotRaw(step, shellCmd) {
  // For cases where we need the raw bash -c form (no login shell)
  const wrapped = `proot-distro login ubuntu -- bash -c '${shellCmd.replace(/'/g, "'\\''")}'`;
  return runTermux(step, wrapped);
}

// ---------------------------------------------------------------------------
// Step implementations
// ---------------------------------------------------------------------------
async function step1() {
  log(1, "Acquiring wakelock...");
  try { execSync("termux-wake-lock", { env: termuxEnv() }); } catch {}
  log(1, "Wakelock acquired.");
}

async function step2() {
  log(2, "Installing proot-distro, android-tools, termux-services, tmux...");
  await runTermux(2, 'pkg install -y proot-distro android-tools termux-services tmux');
  log(2, "Setting up sshd supervision...");
  await runTermux(2, `export SVDIR="${PREFIX}/var/service"; sv-enable sshd 2>/dev/null || rm -f "${PREFIX}/var/service/sshd/down"; pkill -x sshd 2>/dev/null || true; if ! pgrep -x runsvdir >/dev/null 2>&1; then nohup runsvdir -P "${PREFIX}/var/service" </dev/null &>/dev/null & disown 2>/dev/null || true; fi`);
  log(2, "sshd supervised.");
}

async function step3() {
  if (fs.existsSync(ROOTFS)) {
    log(3, "Ubuntu already installed, skipping.");
    return;
  }
  log(3, "Installing Ubuntu via proot-distro (this takes a few minutes)...");
  await runTermux(3, "proot-distro install ubuntu");
  log(3, "Ubuntu installed.");
}

async function step4() {
  log(4, "Installing nvm...");
  await runProot(4, 'if [ -d "$HOME/.nvm" ]; then echo "nvm already installed"; else curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash; fi');
  log(4, "Installing Node.js LTS...");
  await runProot(4, 'source /root/.nvm/nvm.sh && if nvm ls --no-colors 2>/dev/null | grep -q "v[0-9]"; then echo "Node $(node --version) already installed"; else nvm install --lts; fi');
  log(4, "Node.js installed.");
}

async function step5() {
  log(5, "Installing Claude Code...");
  await runProot(5, 'source /root/.nvm/nvm.sh && if command -v claude &>/dev/null; then echo "Claude Code already installed"; else npm install -g @anthropic-ai/claude-code; fi');
  log(5, "Claude Code installed.");
}

// Step 6 — Claude Code Login (interactive)
let claudeLoginProc = null;
let claudeOAuthUrl = null;

async function step6start() {
  log(6, "Starting Claude Code auth login...");
  claudeOAuthUrl = null;

  return new Promise((resolve) => {
    const child = spawn("bash", ["-c",
      `script -qc "proot-distro login ubuntu -- bash -lc 'source /root/.nvm/nvm.sh && claude auth login'" /dev/null`
    ], { env: termuxEnv() });

    claudeLoginProc = child;

    child.stdout.on("data", (data) => {
      const text = data.toString();
      text.split("\n").forEach(line => {
        if (line.trim()) log(6, line.trim());
      });
      // Look for OAuth URL
      const urlMatch = text.match(/(https:\/\/claude\.(?:ai|com)[^\s]*|https:\/\/console\.anthropic\.com[^\s]*)/);
      if (urlMatch && !claudeOAuthUrl) {
        claudeOAuthUrl = urlMatch[1];
        broadcast({ step: 6, status: "waiting", log: "", oauthUrl: claudeOAuthUrl });
      }
    });

    child.stderr.on("data", (data) => {
      data.toString().split("\n").forEach(l => { if (l.trim()) log(6, l.trim()); });
    });

    child.on("close", () => {
      claudeLoginProc = null;
      resolve();
    });

    // Poll for credentials file
    const poll = setInterval(() => {
      const credPath = `${ROOTFS}/root/.claude/.credentials.json`;
      if (fs.existsSync(credPath)) {
        clearInterval(poll);
        log(6, "Credentials detected! Login complete.");
        if (claudeLoginProc) {
          try { claudeLoginProc.kill(); } catch {}
          claudeLoginProc = null;
        }
        resolve();
      }
    }, 2000);

    // Timeout after 10 minutes
    setTimeout(() => {
      clearInterval(poll);
      if (claudeLoginProc) {
        try { claudeLoginProc.kill(); } catch {}
        claudeLoginProc = null;
      }
      resolve();
    }, 600000);
  });
}

async function step7() {
  log(7, "Installing Playwright CLI...");
  await runProot(7, 'source /root/.nvm/nvm.sh && if command -v playwright-cli &>/dev/null; then echo "Playwright CLI already installed"; else npm install -g @playwright/cli@latest; fi');
  log(7, "Installing Playwright skills...");
  await runProot(7, 'source /root/.nvm/nvm.sh && PW_PKG=$(npm root -g)/@playwright/cli && if [ -d "$PW_PKG/skills/playwright-cli" ] && [ ! -f "$HOME/.claude/skills/playwright-cli/SKILL.md" ]; then mkdir -p "$HOME/.claude/skills" && cp -r "$PW_PKG/skills/playwright-cli" "$HOME/.claude/skills/" && echo "Skills installed"; else echo "Skills already present or package not found"; fi');
  log(7, "Installing PostgreSQL, Bun, pnpm, expect, supervisor...");
  await runProot(7, 'DEBIAN_FRONTEND=noninteractive apt-get update -qq && DEBIAN_FRONTEND=noninteractive apt-get install -y -qq postgresql postgresql-client expect supervisor >/dev/null 2>&1 && echo "APT packages installed"');
  log(7, "Installing Bun...");
  await runProot(7, 'if [ -f "$HOME/.bun/bin/bun" ]; then echo "Bun already installed"; else curl -fsSL https://bun.sh/install | bash; fi');
  log(7, "Installing pnpm...");
  await runProot(7, 'source /root/.nvm/nvm.sh && if command -v pnpm &>/dev/null; then echo "pnpm already installed"; else npm install -g pnpm; fi');
  log(7, "Dev tools installed.");
}

async function step8() {
  log(8, "Installing Mobvibe...");

  // Check if already installed
  try {
    const check = execSync(`ls ${ROOTFS}/opt/mobvibe/gateway/apps ${ROOTFS}/opt/mobvibe/cli/apps ${ROOTFS}/opt/mobvibe/webui/index.html 2>/dev/null`, { encoding: "utf8" });
    if (check) {
      log(8, "Mobvibe already installed, regenerating config files...");
    }
  } catch {
    log(8, "Downloading Mobvibe from GitHub releases...");
    await runProot(8, `
mkdir -p /opt/mobvibe/{gateway,webui,cli}
RELEASE_URLS=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/releases/latest" | grep browser_download_url)
GATEWAY_URL=$(echo "$RELEASE_URLS" | grep gateway | sed 's/.*"\\(http[^"]*\\)".*/\\1/')
WEBUI_URL=$(echo "$RELEASE_URLS" | grep webui | sed 's/.*"\\(http[^"]*\\)".*/\\1/')
CLI_URL=$(echo "$RELEASE_URLS" | grep 'cli\\.tar' | sed 's/.*"\\(http[^"]*\\)".*/\\1/')
echo "Downloading gateway..." && curl -fsSL "$GATEWAY_URL" | tar xz -C /opt/mobvibe/gateway
echo "Downloading WebUI..." && curl -fsSL "$WEBUI_URL" | tar xz -C /opt/mobvibe/webui
echo "Configuring WebUI gateway URL..." && find /opt/mobvibe/webui -name "*.js" -exec sed -i 's|__MOBVIBE_GATEWAY_URL__|http://localhost:8080|g' {} + 2>/dev/null
echo "Downloading CLI..." && curl -fsSL "$CLI_URL" | tar xz -C /opt/mobvibe/cli
`);
    log(8, "Installing gateway dependencies...");
    await runProot(8, 'source /root/.nvm/nvm.sh && cd /opt/mobvibe/gateway && pnpm install --frozen-lockfile 2>/dev/null || pnpm install');
    log(8, "Installing CLI dependencies...");
    await runProot(8, 'source /root/.nvm/nvm.sh && cd /opt/mobvibe/cli && pnpm install --frozen-lockfile 2>/dev/null || pnpm install');
  }

  // Generate auth secret
  await runProotRaw(8, 'test -f /opt/mobvibe/.auth-secret || openssl rand -hex 32 > /opt/mobvibe/.auth-secret');

  // Write proxy.js
  log(8, "Writing proxy.js...");
  const proxyJs = `const http = require("http");
const fs = require("fs");
const path = require("path");
const WEBUI = "/opt/mobvibe/webui";
const PORT = 8080;
const MIME = {
  ".html":"text/html",".js":"application/javascript",".css":"text/css",
  ".json":"application/json",".svg":"image/svg+xml",".png":"image/png",
  ".wasm":"application/wasm",".ico":"image/x-icon",".apk":"application/vnd.android.package-archive"
};
function serveStatic(req, res) {
  let fp = path.join(WEBUI, req.url.split("?")[0]);
  if (fp.endsWith("/")) fp += "index.html";
  fs.stat(fp, (err, st) => {
    if (err || !st.isFile()) fp = path.join(WEBUI, "index.html");
    const ext = path.extname(fp);
    res.writeHead(200, {"Content-Type": MIME[ext] || "application/octet-stream"});
    fs.createReadStream(fp).pipe(res);
  });
}
function shouldServeStatic(url) {
  const p = url.split("?")[0];
  if (p === "/") return true;
  if (p.startsWith("/assets/")) return true;
  const ext = path.extname(p);
  return ext && MIME[ext];
}
function handler(req, res) {
  if (shouldServeStatic(req.url)) { serveStatic(req, res); }
  else {
    const opts = {hostname:"127.0.0.1",port:3005,path:req.url,method:req.method,headers:{...req.headers,host:"localhost:3005"}};
    const proxy = http.request(opts, (pRes) => { res.writeHead(pRes.statusCode, pRes.headers); pRes.pipe(res); });
    proxy.on("error", () => serveStatic(req, res));
    req.pipe(proxy);
  }
}
const server = http.createServer(handler);
server.on("upgrade", (req, socket, head) => {
  const opts = {hostname:"127.0.0.1",port:3005,path:req.url,method:"GET",headers:{...req.headers,host:"localhost:3005"}};
  const proxy = http.request(opts);
  proxy.on("upgrade", (pRes, pSocket, pHead) => {
    socket.write("HTTP/1.1 101 Switching Protocols\\r\\n" + Object.entries(pRes.headers).map(([k,v])=>k+": "+v).join("\\r\\n") + "\\r\\n\\r\\n");
    if (pHead.length) socket.write(pHead);
    pSocket.on("error", () => socket.end()); socket.on("error", () => pSocket.end());
    pSocket.pipe(socket); socket.pipe(pSocket);
  });
  proxy.on("error", () => socket.end()); socket.on("error", () => {}); proxy.end();
});
process.on("uncaughtException", (err) => { if (err.code === "ECONNRESET" || err.code === "EPIPE") return; console.error("Uncaught:", err); });
server.listen(PORT, "0.0.0.0", () => console.log("HTTP proxy on http://localhost:"+PORT));
`;
  fs.writeFileSync(`${ROOTFS}/opt/mobvibe/proxy.js`, proxyJs);

  // Write supervisord.conf
  log(8, "Writing supervisord.conf...");
  let pgVersion = "17";
  try { pgVersion = fs.readdirSync(`${ROOTFS}/usr/lib/postgresql`)[0] || "17"; } catch {}
  let nodeBin = "/root/.nvm/versions/node/v22.0.0/bin/node";
  try {
    const nvmDir = `${ROOTFS}/root/.nvm/versions/node`;
    const versions = fs.readdirSync(nvmDir).sort();
    if (versions.length > 0) {
      const ver = versions[versions.length - 1];
      nodeBin = `/root/.nvm/versions/node/${ver}/bin/node`;
    }
  } catch {}
  const nodeVersion = path.basename(path.dirname(path.dirname(nodeBin)));
  const bunBin = "/root/.bun/bin/bun";

  const supervisordConf = `[supervisord]
nodaemon=true
logfile=/opt/mobvibe/supervisord.log
pidfile=/opt/mobvibe/supervisord.pid

[program:postgres]
command=/usr/lib/postgresql/${pgVersion}/bin/postgres -D /var/lib/postgresql/${pgVersion}/main
user=postgres
autorestart=true
stdout_logfile=/opt/mobvibe/postgres.log
stderr_logfile=/opt/mobvibe/postgres.err
priority=1

[program:gateway]
command=${nodeBin} dist/index.js
directory=/opt/mobvibe/gateway/apps/gateway
environment=NODE_ENV=development,DATABASE_URL="postgresql://postgres@localhost:5432/mobvibe",BETTER_AUTH_SECRET="%(ENV_BETTER_AUTH_SECRET)s",SKIP_EMAIL_VERIFICATION=true,PORT=3005,GATEWAY_CORS_ORIGINS="http://localhost:8080"
autorestart=true
stdout_logfile=/opt/mobvibe/gateway.log
stderr_logfile=/opt/mobvibe/gateway.err
priority=2
startsecs=5

[program:proxy]
command=${nodeBin} /opt/mobvibe/proxy.js
autorestart=true
stdout_logfile=/opt/mobvibe/proxy.log
stderr_logfile=/opt/mobvibe/proxy.err
priority=3
startsecs=2

[program:cli-daemon]
command=${bunBin} apps/mobvibe-cli/dist/index.js start --foreground
directory=/opt/mobvibe/cli
environment=MOBVIBE_GATEWAY_URL="http://localhost:3005",HOME="/root",PATH="/root/.bun/bin:/root/.nvm/versions/node/${nodeVersion}/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
autorestart=true
stdout_logfile=/opt/mobvibe/cli.log
stderr_logfile=/opt/mobvibe/cli.err
priority=4
startsecs=10
`;
  fs.writeFileSync(`${ROOTFS}/opt/mobvibe/supervisord.conf`, supervisordConf);

  // Write start.sh
  log(8, "Writing start.sh...");
  const startSh = `#!/bin/bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \\. "$NVM_DIR/nvm.sh"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
PG_VERSION=$(ls /usr/lib/postgresql/ 2>/dev/null | head -1)
PG_DATA="/var/lib/postgresql/$PG_VERSION/main"
if [ ! -d "$PG_DATA/base" ]; then
  chown -R postgres:postgres /var/lib/postgresql/
  su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/initdb -D $PG_DATA" 2>/dev/null
fi
export DATABASE_URL="postgresql://postgres@localhost:5432/mobvibe"
su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA -l $PG_DATA/logfile start" 2>/dev/null || true
sleep 2
su - postgres -c "psql -tc \\"SELECT 1 FROM pg_database WHERE datname='mobvibe'\\" | grep -q 1 || psql -c 'CREATE DATABASE mobvibe;'" 2>/dev/null
cd /opt/mobvibe/gateway/apps/gateway
npx drizzle-kit migrate 2>/dev/null || true
su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA stop" 2>/dev/null
export BETTER_AUTH_SECRET="$(cat /opt/mobvibe/.auth-secret 2>/dev/null)"
echo "Starting all services via supervisord..."
exec supervisord -c /opt/mobvibe/supervisord.conf
`;
  fs.writeFileSync(`${ROOTFS}/opt/mobvibe/start.sh`, startSh, { mode: 0o755 });

  // Configure Mobvibe CLI
  try { fs.mkdirSync(`${ROOTFS}/root/.mobvibe`, { recursive: true }); } catch {}
  fs.writeFileSync(`${ROOTFS}/root/.mobvibe/.config.json`, '{"enabledAgents":["claude-acp"]}');

  log(8, "Mobvibe installed and configured.");
}

async function step9() {
  log(9, "Starting Mobvibe in tmux...");
  try { execSync("tmux kill-session -t mobvibe 2>/dev/null", { env: termuxEnv() }); } catch {}
  await runTermux(9, `tmux new-session -d -s mobvibe "proot-distro login ubuntu -- /bin/bash -lc 'source ~/.nvm/nvm.sh; export BUN_INSTALL=\\$HOME/.bun; export PATH=\\$BUN_INSTALL/bin:\\$PATH; exec /opt/mobvibe/start.sh'"`);
  log(9, "Waiting for gateway on port 3005 (up to 90s)...");
  for (let i = 0; i < 18; i++) {
    try {
      execSync("curl -s --max-time 2 http://localhost:3005 >/dev/null 2>&1", { env: termuxEnv() });
      log(9, "Gateway is up!");
      return;
    } catch {}
    await new Promise(r => setTimeout(r, 5000));
    log(9, `Still waiting... (${(i + 1) * 5}s)`);
  }
  log(9, "WARNING: Gateway may not be fully up yet. Continuing...");
}

async function step10() {
  log(10, "Creating default user...");
  try {
    execSync(`curl -s -X POST http://localhost:3005/api/auth/sign-up/email -H "Content-Type: application/json" -d '{"email":"${MOBVIBE_EMAIL}","password":"${MOBVIBE_PASS}","name":"Admin"}'`, { env: termuxEnv() });
  } catch {}
  log(10, "User created. Logging in CLI for E2EE device registration...");

  // Run expect inside proot for CLI login
  for (let attempt = 1; attempt <= 3; attempt++) {
    await runProot(10, `source /root/.nvm/nvm.sh && export BUN_INSTALL=/root/.bun && export PATH=$BUN_INSTALL/bin:$PATH && expect -c "
spawn env MOBVIBE_GATEWAY_URL=http://localhost:3005 bun /opt/mobvibe/cli/apps/mobvibe-cli/dist/index.js login
expect \\"Email:\\"
send \\"${MOBVIBE_EMAIL}\\r\\"
expect \\"Password:\\"
send \\"${MOBVIBE_PASS}\\r\\"
expect eof
"`);
    try {
      const creds = fs.readFileSync(`${ROOTFS}/root/.mobvibe/credentials.json`, "utf8");
      if (creds.includes("masterSecret")) {
        log(10, "CLI login + device registration complete.");
        break;
      }
    } catch {}
    log(10, `CLI login attempt ${attempt} failed, retrying...`);
    await new Promise(r => setTimeout(r, 3000));
  }

  // Extract masterSecret
  let e2eeSecret = "";
  try {
    const creds = JSON.parse(fs.readFileSync(`${ROOTFS}/root/.mobvibe/credentials.json`, "utf8"));
    e2eeSecret = creds.masterSecret || "";
  } catch {}

  if (!e2eeSecret) {
    log(10, "WARNING: No E2EE master secret found.");
  }

  // Generate auto-login.html - CRITICAL: clear old localStorage before setting new
  log(10, "Generating auto-login.html...");
  const autoLoginHtml = `<!DOCTYPE html>
<html>
<head><title>Logging in...</title></head>
<body>
<p>Logging in...</p>
<script>
(async () => {
  try {
    var secret = "${e2eeSecret}";
    if (secret) {
      localStorage.removeItem("mobvibe_e2ee_master_secret");
      localStorage.removeItem("mobvibe_e2ee_secrets");
      localStorage.setItem("mobvibe_e2ee_master_secret", secret);
      localStorage.setItem("mobvibe_e2ee_secrets", JSON.stringify([
        { secret: secret, fingerprint: "setup", addedAt: Date.now() }
      ]));
    }
    const res = await fetch("/api/auth/sign-in/email", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      credentials: "include",
      body: JSON.stringify({email: "${MOBVIBE_EMAIL}", password: "${MOBVIBE_PASS}"})
    });
    if (res.ok) window.location.href = "/";
    else document.body.innerHTML = "<p>Login failed: " + res.status + "</p>";
  } catch(e) {
    document.body.innerHTML = "<p>Error: " + e.message + "</p>";
  }
})();
</script>
</body>
</html>`;
  fs.writeFileSync(`${ROOTFS}/opt/mobvibe/webui/auto-login.html`, autoLoginHtml);
  log(10, "E2EE setup complete.");
}

// Step 11 — ADB (interactive)
async function step11pair(ip, port, code) {
  log(11, `Pairing with ${ip}:${port}...`);
  const cmd = `echo '${code}' | adb pair ${ip}:${port}`;
  await runTermux(11, cmd);
  log(11, "Pairing complete.");
}

async function step11connect(ip, port) {
  log(11, `Connecting to ${ip}:${port}...`);
  await runTermux(11, `adb connect ${ip}:${port}`);
  // Save address
  fs.writeFileSync(`${TERMUX_HOME}/.adb-connect-addr`, `${ip}:${port}`);
  log(11, `Connected. Address saved to .adb-connect-addr`);

  // Copy proot adb key to Termux so Termux's adb can connect
  log(11, "Copying proot ADB keys to Termux...");
  try {
