#!/bin/bash
# First-run setup wizard — runs inside proot
# Serves a web UI that guides through wakelock + ADB wireless debugging setup

WIZARD_PORT=8888
WIZARD_DIR="/opt/termux-setup-wizard"

mkdir -p "$WIZARD_DIR"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Create the backend + frontend as a single Node script
cat > "$WIZARD_DIR/server.mjs" <<'SERVERJS'
import http from "http";
import { execSync, exec } from "child_process";
import fs from "fs";

const PORT = parseInt(process.env.WIZARD_PORT || "8888");

const HTML = `<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Termux Setup</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #0a0a0a; color: #e5e5e5; padding: 16px; max-width: 600px; margin: 0 auto; }
  h1 { font-size: 1.4em; margin-bottom: 16px; color: #fff; }
  .step { background: #1a1a1a; border: 1px solid #333; border-radius: 8px; padding: 16px; margin-bottom: 12px; }
  .step.done { border-color: #22c55e; }
  .step.active { border-color: #3b82f6; }
  .step h2 { font-size: 1.1em; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
  .step p { font-size: 0.9em; color: #999; margin-bottom: 8px; line-height: 1.5; }
  .step .status { font-size: 0.85em; padding: 4px 8px; border-radius: 4px; }
  .status.ok { background: #052e16; color: #22c55e; }
  .status.pending { background: #1e1b4b; color: #818cf8; }
  .status.error { background: #450a0a; color: #ef4444; }
  input { background: #111; border: 1px solid #444; color: #fff; padding: 8px 12px; border-radius: 6px; width: 100%; font-size: 16px; margin-bottom: 8px; }
  button { background: #3b82f6; color: #fff; border: none; padding: 10px 20px; border-radius: 6px; font-size: 0.95em; cursor: pointer; width: 100%; }
  button:disabled { opacity: 0.5; cursor: not-allowed; }
  button:hover:not(:disabled) { background: #2563eb; }
  .hint { font-size: 0.8em; color: #666; margin-top: 4px; }
  .row { display: flex; gap: 8px; }
  .row input { flex: 1; }
  #log { font-family: monospace; font-size: 0.8em; background: #111; padding: 8px; border-radius: 6px; max-height: 150px; overflow-y: auto; white-space: pre-wrap; margin-top: 8px; display: none; }
</style>
</head>
<body>
<h1>Termux Setup Wizard</h1>
<p style="font-size:0.85em;color:#666;margin-bottom:12px;">ADB pairing survives reboots, but the connection doesn't. Termux will auto-reconnect on launch. Re-run this wizard anytime with: <code style="background:#222;padding:2px 6px;border-radius:4px;">termux-setup-wizard</code></p>

<div class="step" id="step1">
  <h2><span id="s1icon">1.</span> Acquire Wakelock</h2>
  <p>Prevents Android from killing Termux in the background.</p>
  <button onclick="checkWakelock()">Acquire Wakelock</button>
  <div id="s1status"></div>
</div>

<div class="step" id="step2">
  <h2><span id="s2icon">2.</span> Enable Wireless Debugging</h2>
  <p>Go to <b>Settings &rarr; Developer options &rarr; Wireless debugging</b> and enable it.</p>
  <p class="hint">If you don't see Developer options: go to Settings &rarr; About phone &rarr; tap "Build number" 7 times.</p>
</div>

<div class="step" id="step3">
  <h2><span id="s3icon">3.</span> Pair ADB</h2>
  <p>In Wireless debugging settings, tap <b>"Pair device with pairing code"</b>. Enter the info below quickly (it expires):</p>
  <div class="row">
    <input id="pairIp" placeholder="IP (e.g. 192.168.1.5)">
    <input id="pairPort" placeholder="Port" style="max-width: 80px;">
    <input id="pairCode" placeholder="Code" style="max-width: 80px;">
  </div>
  <button onclick="doPair()" id="pairBtn">Pair</button>
  <div id="s3status"></div>
</div>

<div class="step" id="step4">
  <h2><span id="s4icon">4.</span> Connect ADB</h2>
  <p>Enter the <b>Port</b> shown at the top of the Wireless debugging screen (the IP is the same as pairing):</p>
  <div class="row">
    <input id="connectIp" placeholder="IP">
    <input id="connectPort" placeholder="Port" style="max-width: 100px;">
  </div>
  <button onclick="doConnect()" id="connectBtn">Connect</button>
  <div id="s4status"></div>
</div>

<div class="step" id="step5">
  <h2><span id="s5icon">5.</span> Verify Browser Debugging</h2>
  <p>Make sure Chrome is open on this device, then verify the debug connection.</p>
  <button onclick="doForward()" id="forwardBtn">Verify Chrome Debug Access</button>
  <div id="s5status"></div>
</div>

<div class="step" id="step6">
  <h2><span id="s6icon">6.</span> Done!</h2>
  <p>All set. Click below to finish and close the wizard. You can re-run it anytime with <code>termux-setup-wizard</code>.</p>
  <button onclick="doFinish()" id="finishBtn">Complete Setup</button>
  <div id="s6status"></div>
</div>

<div id="log"></div>

<script>
function log(msg) {
  const el = document.getElementById("log");
  el.style.display = "block";
  el.textContent += msg + "\\n";
  el.scrollTop = el.scrollHeight;
}

function setStatus(id, cls, text) {
  document.getElementById(id).innerHTML = '<div class="status ' + cls + '">' + text + '</div>';
}

function markDone(n) {
  document.getElementById("step" + n).classList.add("done");
  document.getElementById("step" + n).classList.remove("active");
  document.getElementById("s" + n + "icon").textContent = "\\u2713";
}

function markActive(n) {
  document.getElementById("step" + n).classList.add("active");
}

async function api(action, params) {
  const res = await fetch("/api/" + action, {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify(params)
  });
  return res.json();
}

async function checkWakelock() {
  const r = await api("check-wakelock");
  if (r.held) {
    setStatus("s1status", "ok", "Wakelock is held");
    markDone(1);
    markActive(2);
  } else {
    setStatus("s1status", "pending", "Wakelock not held. Pull down notifications and tap Termux &rarr; Acquire wakelock");
  }
}

async function doPair() {
  const ip = document.getElementById("pairIp").value.trim();
  const port = document.getElementById("pairPort").value.trim();
  const code = document.getElementById("pairCode").value.trim();
  if (!ip || !port || !code) { setStatus("s3status", "error", "Enter IP, port, and code"); return; }
  document.getElementById("pairBtn").disabled = true;
  setStatus("s3status", "pending", "Pairing...");
  const r = await api("pair", {address: ip + ":" + port, code: code});
  document.getElementById("pairBtn").disabled = false;
  if (r.success) {
    setStatus("s3status", "ok", "Paired successfully!");
    markDone(3);
    markActive(4);
    // Auto-fill connect IP
    document.getElementById("connectIp").value = ip;
    document.getElementById("connectPort").focus();
    log(r.output);
  } else {
    setStatus("s3status", "error", "Pairing failed: " + (r.output || r.error));
    log(r.output || r.error);
  }
}

async function doConnect() {
  const ip = document.getElementById("connectIp").value.trim();
  const port = document.getElementById("connectPort").value.trim();
  if (!ip || !port) { setStatus("s4status", "error", "Enter IP and port"); return; }
  const addr = ip + ":" + port;
  document.getElementById("connectBtn").disabled = true;
  setStatus("s4status", "pending", "Connecting...");
  const r = await api("connect", {address: addr});
  document.getElementById("connectBtn").disabled = false;
  if (r.success) {
    setStatus("s4status", "ok", "Connected to " + addr);
    markDone(4);
    markActive(5);
    log(r.output);
  } else {
    setStatus("s4status", "error", "Connection failed: " + (r.output || r.error));
    log(r.output || r.error);
  }
}

async function doForward() {
  document.getElementById("forwardBtn").disabled = true;
  setStatus("s5status", "pending", "Setting up Chrome debug port...");
  const r = await api("forward");
  document.getElementById("forwardBtn").disabled = false;
  if (r.success) {
    setStatus("s5status", "ok", "Chrome debugging ready! Browser: " + (r.browser || "detected"));
    markDone(5);
    log(r.output);
  } else {
    setStatus("s5status", "error", "Failed: " + (r.output || r.error));
    log(r.output || r.error);
  }
}

async function doFinish() {
  const r = await api("finish");
  if (r.success) {
    setStatus("s6status", "ok", "Setup complete! You can close this tab.");
    markDone(6);
  }
}

// Auto-fill local IP
async function autofillIp() {
  const r = await api("get-ip");
  if (r.ip) document.getElementById("pairIp").value = r.ip;
}
autofillIp();

markActive(1);
</script>
</body>
</html>`;

function run(cmd, timeout = 10000) {
  try {
    return { success: true, output: execSync(cmd, { timeout, encoding: "utf-8" }).trim() };
  } catch (e) {
    return { success: false, output: e.stderr?.trim() || e.message, error: e.message };
  }
}

const server = http.createServer((req, res) => {
  if (req.method === "GET") {
    res.writeHead(200, { "Content-Type": "text/html" });
    res.end(HTML);
    return;
  }

  if (req.method === "POST" && req.url.startsWith("/api/")) {
    let body = "";
    req.on("data", c => body += c);
    req.on("end", () => {
      const params = body ? JSON.parse(body) : {};
      const action = req.url.replace("/api/", "");
      let result;

      switch (action) {
        case "check-wakelock": {
          // Acquire wakelock and report success
          run("termux-wake-lock");
          result = { held: true };
          break;
        }
        case "get-ip": {
          const r = run("ifconfig 2>/dev/null | grep -oP 'inet \\K[\\d.]+' | grep -v '^127\\.' | head -1");
          result = { ip: r.success ? r.output : null };
          break;
        }
        case "pair": {
          result = run(`adb pair ${params.address} ${params.code}`, 15000);
          result.success = result.output?.includes("Successfully paired") || false;
          break;
        }
        case "connect": {
          result = run(`adb connect ${params.address}`, 10000);
          result.success = result.output?.includes("connected") || false;
          if (result.success) {
            // Save address for auto-reconnect on next Termux launch
            const termuxHome = "/data/data/com.termux/files/home";
            fs.writeFileSync(`${termuxHome}/.adb-connect-addr`, params.address);
          }
          break;
        }
        case "forward": {
          // Find devtools socket and forward
          const sockets = run("adb shell cat /proc/net/unix 2>/dev/null | grep devtools");
          if (!sockets.success) {
            result = { success: false, error: "No ADB device connected or no browser running" };
            break;
          }
          run("adb forward tcp:9222 localabstract:chrome_devtools_remote");
          const version = run("curl -s --max-time 3 http://localhost:9222/json/version");
          if (version.success && version.output.includes("Browser")) {
            try {
              const info = JSON.parse(version.output);
              result = { success: true, browser: info.Browser, output: version.output };
            } catch {
              result = { success: true, browser: "unknown", output: version.output };
            }
          } else {
            // Try PID-specific socket
            const pidSocket = sockets.output.split("\n").find(l => l.includes("_"));
            if (pidSocket) {
              const name = pidSocket.match(/@(chrome_devtools_remote_\d+)/)?.[1];
              if (name) {
                run(`adb forward tcp:9222 localabstract:${name}`);
                const v2 = run("curl -s --max-time 3 http://localhost:9222/json/version");
                if (v2.success && v2.output.includes("Browser")) {
                  try {
                    const info = JSON.parse(v2.output);
                    result = { success: true, browser: info.Browser, output: v2.output };
                  } catch {
                    result = { success: true, browser: "unknown", output: v2.output };
                  }
                } else {
                  result = { success: false, error: "Chrome devtools not responding", output: v2.output };
                }
              }
            }
            if (!result) {
              result = { success: false, error: "Could not connect to Chrome devtools" };
            }
          }
          break;
        }
        case "finish": {
          const termuxHome = "/data/data/com.termux/files/home";
          fs.writeFileSync(`${termuxHome}/.termux-setup-done`, new Date().toISOString());
          result = { success: true };
          setTimeout(() => process.exit(0), 1000);
          break;
        }
        default:
          result = { success: false, error: "Unknown action: " + action };
      }

      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(JSON.stringify(result));
    });
    return;
  }

  res.writeHead(404);
  res.end("Not found");
});

server.listen(PORT, "0.0.0.0", () => {
  console.log(`Setup wizard running at http://localhost:${PORT}`);
  // Try to open in browser
  try { execSync(`termux-open-url http://localhost:${PORT}`); } catch {}
});
SERVERJS

# Kill any existing wizard
kill $(cat /tmp/setup-wizard.pid 2>/dev/null) 2>/dev/null

# Start wizard server
node "$WIZARD_DIR/server.mjs" &
WIZARD_PID=$!
echo $WIZARD_PID > /tmp/setup-wizard.pid

termux-open-url "http://localhost:$WIZARD_PORT" 2>/dev/null

echo ""
echo "============================================"
echo "  Setup wizard running at:"
echo "  http://localhost:$WIZARD_PORT"
echo ""
echo "  Open in your browser to continue setup."
echo "  The wizard will mark setup as complete"
echo "  once all steps are done."
echo "============================================"

# Wait for user to complete - wizard sets the flag
wait $WIZARD_PID 2>/dev/null
