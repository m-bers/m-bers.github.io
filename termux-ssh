#!/data/data/com.termux/files/usr/bin/bash
set -e

GITHUB_USER="m-bers"

echo "================================"
echo "  Termux SSH Quick Setup"
echo "================================"
echo ""

pkg update -y
pkg install -y openssh tmux

mkdir -p ~/.ssh
chmod 700 ~/.ssh

echo "Pulling SSH keys from github.com/$GITHUB_USER..."
curl -fsSL "https://github.com/$GITHUB_USER.keys" > ~/.ssh/authorized_keys
chmod 600 ~/.ssh/authorized_keys

NKEYS=$(wc -l < ~/.ssh/authorized_keys)
echo "Imported $NKEYS key(s)."

passwd </dev/tty

sshd

IP=$(ifconfig 2>/dev/null | grep 'inet ' | grep -v '127.0.0.1' | awk '{print $2}' | head -1)
USER=$(whoami)

echo ""
echo "================================"
echo "  SSH ready!"
echo ""
echo "  Connect with:"
echo "    ssh -p 8022 $USER@$IP"
echo ""
echo "  Then run the full setup:"
echo "    tmux new -s setup"
echo "    curl -fsSL https://joshcha.mbe.rs/termux | bash"
echo "================================"
