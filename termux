#!/data/data/com.termux/files/usr/bin/bash
set -e

GITHUB_USER="m-bers"
GITHUB_REPO="m-bers/m-bers.github.io"

echo "============================================"
echo "  Termux + Claude Code + Mobvibe Setup"
echo "============================================"
echo ""

# --- Step 1: Set mirror and update ---
echo "[1/8] Setting package mirror and updating..."
mkdir -p "$PREFIX/etc/apt"
echo "deb https://packages.termux.dev/apt/termux-main stable main" > "$PREFIX/etc/apt/sources.list"
pkg update -y
DEBIAN_FRONTEND=noninteractive pkg upgrade -y -o Dpkg::Options::="--force-confold"

# --- Step 2: Install core Termux packages ---
echo ""
echo "[2/8] Installing core Termux packages..."
pkg install -y proot-distro openssh

# --- Step 3: SSH setup with GitHub keys ---
echo ""
echo "[3/8] Setting up SSH with GitHub keys..."
mkdir -p ~/.ssh
chmod 700 ~/.ssh
echo "  Pulling SSH keys from github.com/$GITHUB_USER..."
curl -fsSL "https://github.com/$GITHUB_USER.keys" > ~/.ssh/authorized_keys
chmod 600 ~/.ssh/authorized_keys
NKEYS=$(wc -l < ~/.ssh/authorized_keys)
echo "  Imported $NKEYS key(s). Starting sshd on port 8022..."
sshd

# --- Step 4: Optional Termux integrations ---
echo ""
echo "[4/8] Checking optional Termux integrations..."

# Termux:API — clipboard, notifications, sensors, etc.
if pm list packages 2>/dev/null | grep -q 'com.termux.api'; then
  echo "  Termux:API app detected — installing termux-api package..."
  pkg install -y termux-api
else
  echo "  Termux:API app not installed, skipping."
  echo "    Install from F-Droid for clipboard, notifications, etc."
fi

# Termux:Boot — run scripts on device boot
if pm list packages 2>/dev/null | grep -q 'com.termux.boot'; then
  echo "  Termux:Boot app detected — setting up boot scripts..."
  mkdir -p ~/.termux/boot
  cat > ~/.termux/boot/start-mobvibe.sh <<'BOOT'
#!/data/data/com.termux/files/usr/bin/bash
termux-wake-lock
proot-distro login ubuntu -- /bin/bash -c "source ~/.nvm/nvm.sh && /opt/mobvibe/start.sh &>/dev/null &"
BOOT
  chmod +x ~/.termux/boot/start-mobvibe.sh
  echo "    Created boot script to auto-start Mobvibe."
else
  echo "  Termux:Boot app not installed, skipping."
  echo "    Install from F-Droid to auto-start on device boot."
fi

# Termux:Widget — home screen shortcuts
if pm list packages 2>/dev/null | grep -q 'com.termux.widget'; then
  echo "  Termux:Widget app detected — creating shortcuts..."
  mkdir -p ~/.shortcuts
  cat > ~/.shortcuts/Claude.sh <<'WIDGET_CLAUDE'
#!/data/data/com.termux/files/usr/bin/bash
proot-distro login ubuntu -- /bin/bash -lc "claude"
WIDGET_CLAUDE
  chmod +x ~/.shortcuts/Claude.sh
  echo "    Created 'Claude' home screen shortcut."
else
  echo "  Termux:Widget app not installed, skipping."
  echo "    Install from F-Droid for home screen shortcuts."
fi

# --- Step 5: Storage access ---
echo ""
echo "[5/8] Setting up storage access..."
if [ -d ~/storage/shared ]; then
  echo "  Storage already configured, skipping."
else
  echo "  Granting storage access (tap Allow on the prompt)..."
  termux-setup-storage </dev/tty
  echo "  Storage configured at ~/storage/"
fi

# --- Step 6: Install Ubuntu in proot ---
echo ""
echo "[6/8] Installing Ubuntu via proot-distro..."
if proot-distro list --installed 2>/dev/null | grep -q ubuntu; then
  echo "  Ubuntu already installed, skipping."
else
  proot-distro install ubuntu
fi

# --- Step 7: Bootstrap inside proot ---
echo ""
echo "[7/8] Bootstrapping inside proot Ubuntu..."

proot-distro login ubuntu -- bash -c 'bash -s' <<'INNER_SCRIPT'
set -e

echo ""
echo "=== Inside proot Ubuntu ==="
echo ""

# --- Ensure Termux commands are accessible ---
TERMUX_BIN="/data/data/com.termux/files/usr/bin"
if [ -d "$TERMUX_BIN" ] && ! echo "$PATH" | grep -q "$TERMUX_BIN"; then
  export PATH="$PATH:$TERMUX_BIN"
fi
if [ -d "$TERMUX_BIN" ] && ! grep -q "$TERMUX_BIN" /etc/environment 2>/dev/null; then
  sed -i "s|^PATH=\(.*\)|PATH=\1:$TERMUX_BIN|" /etc/environment
  echo "Added Termux bin to /etc/environment PATH"
fi

# --- Install nvm ---
echo "[proot 1/7] Installing nvm..."
if [ -d "$HOME/.nvm" ]; then
  echo "  nvm already installed, skipping."
else
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# --- Install Node ---
echo ""
echo "[proot 2/7] Installing Node.js (latest LTS)..."
if command -v node &>/dev/null; then
  echo "  Node $(node --version) already installed, skipping."
else
  nvm install --lts
fi

# --- Install Claude Code ---
echo ""
echo "[proot 3/7] Installing Claude Code..."
if command -v claude &>/dev/null; then
  echo "  Claude Code already installed, skipping."
else
  npm install -g @anthropic-ai/claude-code
fi

# --- Claude Code login (interactive) ---
echo ""
if [ -e /dev/tty ]; then
  echo "============================================"
  echo "[proot 3.5/7] Claude Code login required."
  echo "  This will open a browser or give you a URL."
  echo "============================================"
  echo ""
  claude auth login </dev/tty
  echo ""
  echo "Claude Code login complete!"
else
  echo "[proot 3.5/7] Skipping Claude Code login (no TTY)."
  echo "  Run manually: proot-distro login ubuntu"
  echo "  Then: claude auth login"
fi

# --- Install PostgreSQL ---
echo ""
echo "[proot 4/7] Installing PostgreSQL..."
if command -v pg_isready &>/dev/null; then
  echo "  PostgreSQL already installed, skipping."
else
  apt-get update -qq
  DEBIAN_FRONTEND=noninteractive apt-get install -y -qq postgresql postgresql-client >/dev/null
fi

# --- Start PostgreSQL and create database ---
echo "[proot 4.5/7] Configuring PostgreSQL..."
PG_VERSION=$(ls /usr/lib/postgresql/ 2>/dev/null | head -1)
if [ -n "$PG_VERSION" ]; then
  PG_DATA="/var/lib/postgresql/$PG_VERSION/main"
  if [ ! -d "$PG_DATA/base" ]; then
    mkdir -p "$PG_DATA"
    chown -R postgres:postgres /var/lib/postgresql/
    su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/initdb -D $PG_DATA" 2>/dev/null
  fi
  su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA -l $PG_DATA/logfile start" 2>/dev/null || true
  sleep 2
  su - postgres -c "psql -tc \"SELECT 1 FROM pg_database WHERE datname='mobvibe'\" | grep -q 1 || psql -c 'CREATE DATABASE mobvibe;'" 2>/dev/null
  echo "  PostgreSQL running, database 'mobvibe' ready."
fi

# --- Install Bun ---
echo ""
echo "[proot 5/7] Installing Bun..."
if command -v bun &>/dev/null; then
  echo "  Bun already installed, skipping."
else
  curl -fsSL https://bun.sh/install | bash
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
fi
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# --- Install pnpm ---
echo "[proot 5.5/7] Installing pnpm..."
if command -v pnpm &>/dev/null; then
  echo "  pnpm already installed, skipping."
else
  npm install -g pnpm
fi

# --- Download and install Mobvibe ---
echo ""
echo "[proot 6/7] Installing Mobvibe..."
MOBVIBE_DIR="/opt/mobvibe"
if [ -d "$MOBVIBE_DIR/gateway" ]; then
  echo "  Mobvibe already installed, skipping download."
else
  mkdir -p "$MOBVIBE_DIR"/{gateway,webui,cli}

  RELEASE_URLS=$(curl -fsSL "https://api.github.com/repos/m-bers/m-bers.github.io/releases/latest" | grep browser_download_url)

  GATEWAY_URL=$(echo "$RELEASE_URLS" | grep gateway | sed 's/.*"\(http[^"]*\)".*/\1/')
  WEBUI_URL=$(echo "$RELEASE_URLS" | grep webui | sed 's/.*"\(http[^"]*\)".*/\1/')
  CLI_URL=$(echo "$RELEASE_URLS" | grep 'cli\.tar' | sed 's/.*"\(http[^"]*\)".*/\1/')

  echo "  Downloading gateway..."
  curl -fsSL "$GATEWAY_URL" | tar xz -C "$MOBVIBE_DIR/gateway"

  echo "  Downloading WebUI..."
  curl -fsSL "$WEBUI_URL" | tar xz -C "$MOBVIBE_DIR/webui"

  echo "  Downloading CLI..."
  curl -fsSL "$CLI_URL" | tar xz -C "$MOBVIBE_DIR/cli"

  # Install gateway dependencies
  echo "  Installing gateway dependencies..."
  cd "$MOBVIBE_DIR/gateway"
  pnpm install --frozen-lockfile 2>/dev/null || pnpm install

  # Install CLI dependencies
  echo "  Installing CLI dependencies..."
  cd "$MOBVIBE_DIR/cli"
  pnpm install --frozen-lockfile 2>/dev/null || pnpm install
fi

# --- Create Mobvibe startup script ---
cat > "$MOBVIBE_DIR/start.sh" <<'MOBVIBE_START'
#!/bin/bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

PG_VERSION=$(ls /usr/lib/postgresql/ 2>/dev/null | head -1)
PG_DATA="/var/lib/postgresql/$PG_VERSION/main"

# Start PostgreSQL
su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA -l $PG_DATA/logfile start" 2>/dev/null || true
sleep 2

# Start gateway
export DATABASE_URL="postgresql://postgres@localhost:5432/mobvibe"
export BETTER_AUTH_SECRET="$(cat /opt/mobvibe/.auth-secret 2>/dev/null)"
export SKIP_EMAIL_VERIFICATION=true
export PORT=3005
export GATEWAY_CORS_ORIGINS="http://localhost:8080"

cd /opt/mobvibe/gateway/apps/gateway
npx drizzle-kit migrate 2>/dev/null
node dist/index.js &

# Serve WebUI
npm install -g serve 2>/dev/null
cd /opt/mobvibe/webui
serve -s -l 8080 &>/dev/null &

echo "Mobvibe running:"
echo "  WebUI:   http://localhost:8080"
echo "  Gateway: http://localhost:3005"
MOBVIBE_START
chmod +x "$MOBVIBE_DIR/start.sh"

# Generate auth secret if not exists
if [ ! -f "$MOBVIBE_DIR/.auth-secret" ]; then
  openssl rand -hex 32 > "$MOBVIBE_DIR/.auth-secret"
fi

# --- Mobvibe login (interactive) ---
echo ""
echo "[proot 7/7] Setting up Mobvibe CLI..."
export MOBVIBE_GATEWAY_URL="http://localhost:3005"

# Start services for initial login
"$MOBVIBE_DIR/start.sh" &>/dev/null &
sleep 3

if [ -e /dev/tty ]; then
  echo "============================================"
  echo "  Mobvibe CLI login required."
  echo "============================================"
  echo ""
  cd "$MOBVIBE_DIR/cli"
  MOBVIBE_GATEWAY_URL="http://localhost:3005" bun apps/mobvibe-cli/dist/index.js login </dev/tty
  echo ""
  echo "Mobvibe login complete!"
else
  echo "  Skipping Mobvibe login (no TTY)."
  echo "  Run manually: /opt/mobvibe/start.sh"
  echo "  Then: cd /opt/mobvibe/cli && MOBVIBE_GATEWAY_URL=http://localhost:3005 bun apps/mobvibe-cli/dist/index.js login"
fi

echo ""
echo "============================================"
echo "  Setup complete!"
echo ""
echo "  To start: proot-distro login ubuntu"
echo "  Then run: /opt/mobvibe/start.sh"
echo ""
echo "  WebUI:   http://localhost:8080"
echo "  Gateway: http://localhost:3005"
echo "============================================"

INNER_SCRIPT

# --- Step 8: Auto-start Mobvibe from Termux ---
echo ""
echo "[8/8] Configuring auto-start..."
if ! grep -q 'mobvibe' ~/.bashrc 2>/dev/null; then
  cat >> ~/.bashrc <<'TERMUX_BASHRC'

# Auto-start Mobvibe inside proot
if command -v proot-distro &>/dev/null; then
  proot-distro login ubuntu -- /bin/bash -c 'source ~/.nvm/nvm.sh 2>/dev/null; /opt/mobvibe/start.sh &>/dev/null &'
fi
TERMUX_BASHRC
  echo "Added Mobvibe auto-start to Termux .bashrc"
fi

echo ""
echo "============================================"
echo "  All done! Open http://localhost:8080"
echo "  in your phone's browser to use Mobvibe."
echo "============================================"
