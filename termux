# --- Create startup script ---
cat > "$MOBVIBE_DIR/start.sh" <<'STARTSH'
#!/bin/bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Initialize PostgreSQL data dir if needed
PG_VERSION=$(ls /usr/lib/postgresql/ 2>/dev/null | head -1)
PG_DATA="/var/lib/postgresql/$PG_VERSION/main"
if [ ! -d "$PG_DATA/base" ]; then
  chown -R postgres:postgres /var/lib/postgresql/
  su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/initdb -D $PG_DATA" 2>/dev/null
fi

# Run drizzle migrations once before supervisord starts
export DATABASE_URL="postgresql://postgres@localhost:5432/mobvibe"
su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA -l $PG_DATA/logfile start" 2>/dev/null || true
sleep 2
su - postgres -c "psql -tc \"SELECT 1 FROM pg_database WHERE datname='mobvibe'\" | grep -q 1 || psql -c 'CREATE DATABASE mobvibe;'" 2>/dev/null
cd /opt/mobvibe/gateway/apps/gateway
npx drizzle-kit migrate 2>/dev/null || true
su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA stop" 2>/dev/null

# Export env for supervisord
export BETTER_AUTH_SECRET="$(cat /opt/mobvibe/.auth-secret 2>/dev/null)"

echo "Starting all services via supervisord..."
echo "  WebUI:   http://localhost:8080"
echo "  Gateway: http://localhost:3005"
exec supervisord -c /opt/mobvibe/supervisord.conf
STARTSH
chmod +x "$MOBVIBE_DIR/start.sh"

# --- Configure Mobvibe CLI ---
echo ""
echo "[proot 7/9] Configuring Mobvibe CLI..."
mkdir -p ~/.mobvibe
echo '{"enabledAgents":["claude-acp"]}' > ~/.mobvibe/.config.json

# --- Start services, create user, login CLI ---
echo ""
echo "[proot 8/9] Starting Mobvibe and creating default user..."
set +e  # Disable exit-on-error for service startup

# Start supervisord in foreground of this proot session. We background it here
# but the proot session stays alive because we wait below. The Termux-side
# .bashrc and boot script use tmux for persistence on subsequent launches.
"$MOBVIBE_DIR/start.sh" &
SUPERVISORD_PID=$!
echo "  supervisord PID=$SUPERVISORD_PID"

# Wait for gateway to be ready (up to 90s — first boot may compile drizzle etc.)
echo "  Waiting for gateway..."
for i in $(seq 1 18); do
  curl -s --max-time 2 http://localhost:3005 >/dev/null 2>&1 && break
  sleep 5
done

if ! curl -s --max-time 2 http://localhost:3005 >/dev/null 2>&1; then
  echo "  ERROR: Gateway failed to start. Check /opt/mobvibe/gateway.err"
  echo "  Continuing anyway..."
fi

# Create default user (idempotent — sign-up returns 200 even if exists)
echo "  Creating default user..."
curl -s -X POST http://localhost:3005/api/auth/sign-up/email \
  -H "Content-Type: application/json" \
  -d '{"email":"'"$MOBVIBE_EMAIL"'","password":"'"$MOBVIBE_PASS"'","name":"Admin"}' >/dev/null 2>&1

# Login CLI via expect (registers device + generates masterSecret for E2EE)
echo "  Logging in CLI (registers device for E2EE)..."
for attempt in 1 2 3; do
  expect -c "
spawn env MOBVIBE_GATEWAY_URL=http://localhost:3005 bun /opt/mobvibe/cli/apps/mobvibe-cli/dist/index.js login
expect \"Email:\"
send \"$MOBVIBE_EMAIL\r\"
expect \"Password:\"
send \"$MOBVIBE_PASS\r\"
expect eof
" 2>/dev/null
  if [ -f ~/.mobvibe/credentials.json ] && grep -q masterSecret ~/.mobvibe/credentials.json 2>/dev/null; then
    echo "  CLI login + device registration complete."
    break
  fi
  echo "  CLI login attempt $attempt failed, retrying..."
  sleep 3
done

# Extract masterSecret for WebUI E2EE pairing
E2EE_SECRET=$(grep -o '"masterSecret": *"[^"]*"' ~/.mobvibe/credentials.json 2>/dev/null | sed 's/.*"\([A-Za-z0-9+/=]*\)".*/\1/')

if [ -z "$E2EE_SECRET" ]; then
  echo "  WARNING: No E2EE master secret found. E2EE pairing will need manual setup."
fi

# Create auto-login page that:
# 1. Sets the E2EE master secret in localStorage (WebUI picks it up on init)
# 2. Signs in with default credentials
# 3. Redirects to main app
cat > "$MOBVIBE_DIR/webui/auto-login.html" <<AUTOLOGIN
<!DOCTYPE html>
<html>
<head><title>Logging in...</title></head>
<body>
<p>Logging in...</p>
<script>
(async () => {
  try {
    // Store E2EE master secret in BOTH formats so WebUI can decrypt immediately.
    // Legacy format: single secret (fallback for older WebUI versions).
    // New format: array of StoredSecret objects (what WebUI actually uses).
    var secret = "$E2EE_SECRET";
    if (secret) {
      localStorage.setItem("mobvibe_e2ee_master_secret", secret);
      if (!localStorage.getItem("mobvibe_e2ee_secrets")) {
        localStorage.setItem("mobvibe_e2ee_secrets", JSON.stringify([
          { secret: secret, fingerprint: "setup", addedAt: Date.now() }
        ]));
      }
    }
    const res = await fetch("/api/auth/sign-in/email", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      credentials: "include",
      body: JSON.stringify({email: "$MOBVIBE_EMAIL", password: "$MOBVIBE_PASS"})
    });
    if (res.ok) window.location.href = "/";
    else document.body.innerHTML = "<p>Login failed: " + res.status + "</p>";
  } catch(e) {
    document.body.innerHTML = "<p>Error: " + e.message + "</p>";
  }
})();
</script>
</body>
</html>
AUTOLOGIN

