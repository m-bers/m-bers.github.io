  echo "  Installing CLI dependencies..."
  cd "$MOBVIBE_DIR/cli"
  pnpm install --frozen-lockfile 2>/dev/null || pnpm install
fi

# --- Generate auth secret ---
if [ ! -f "$MOBVIBE_DIR/.auth-secret" ]; then
