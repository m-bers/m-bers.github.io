echo "[3/7] Setting up SSH with GitHub keys..."
mkdir -p ~/.ssh
chmod 700 ~/.ssh
echo "  Pulling SSH keys from github.com/$GITHUB_USER..."
curl -fsSL "https://github.com/$GITHUB_USER.keys" > ~/.ssh/authorized_keys
chmod 600 ~/.ssh/authorized_keys
NKEYS=$(wc -l < ~/.ssh/authorized_keys)
