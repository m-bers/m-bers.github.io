#!/data/data/com.termux/files/usr/bin/bash
set -e

echo "============================================"
echo "  Termux + Claude Code + Happy Coder Setup"
echo "============================================"
echo ""

# --- Step 1: Set mirror and update ---
echo "[1/6] Setting package mirror and updating..."
mkdir -p "$PREFIX/etc/apt"
echo "deb https://packages.termux.dev/apt/termux-main stable main" > "$PREFIX/etc/apt/sources.list"
pkg update -y
DEBIAN_FRONTEND=noninteractive pkg upgrade -y -o Dpkg::Options::="--force-confold"

# --- Step 2: Install core Termux packages ---
echo ""
echo "[2/6] Installing core Termux packages..."
pkg install -y proot-distro

# --- Step 3: Optional Termux integrations ---
echo ""
echo "[3/6] Checking optional Termux integrations..."

# Termux:API — clipboard, notifications, sensors, etc.
if pm list packages 2>/dev/null | grep -q 'com.termux.api'; then
  echo "  Termux:API app detected — installing termux-api package..."
  pkg install -y termux-api
else
  echo "  Termux:API app not installed, skipping."
  echo "    Install from F-Droid for clipboard, notifications, etc."
fi

# Termux:Boot — run scripts on device boot
if pm list packages 2>/dev/null | grep -q 'com.termux.boot'; then
  echo "  Termux:Boot app detected — setting up boot scripts..."
  mkdir -p ~/.termux/boot
  cat > ~/.termux/boot/start-happy-daemon.sh <<'BOOT'
#!/data/data/com.termux/files/usr/bin/bash
termux-wake-lock
proot-distro login ubuntu -- /bin/bash -c "source ~/.nvm/nvm.sh && happy daemon start &>/dev/null &"
BOOT
  chmod +x ~/.termux/boot/start-happy-daemon.sh
  echo "    Created boot script to auto-start happy daemon."
else
  echo "  Termux:Boot app not installed, skipping."
  echo "    Install from F-Droid to auto-start on device boot."
fi

# Termux:Widget — home screen shortcuts
if pm list packages 2>/dev/null | grep -q 'com.termux.widget'; then
  echo "  Termux:Widget app detected — creating shortcuts..."
  mkdir -p ~/.shortcuts
  cat > ~/.shortcuts/Claude.sh <<'WIDGET_CLAUDE'
#!/data/data/com.termux/files/usr/bin/bash
proot-distro login ubuntu -- /bin/bash -lc "happy"
WIDGET_CLAUDE
  chmod +x ~/.shortcuts/Claude.sh
  echo "    Created 'Claude' home screen shortcut."
else
  echo "  Termux:Widget app not installed, skipping."
  echo "    Install from F-Droid for home screen shortcuts."
fi

# --- Step 4: Storage access ---
echo ""
echo "[4/6] Setting up storage access..."
if [ -d ~/storage/shared ]; then
  echo "  Storage already configured, skipping."
else
  echo "  Granting storage access (tap Allow on the prompt)..."
  termux-setup-storage </dev/tty
  echo "  Storage configured at ~/storage/"
fi

# --- Step 5: Install Ubuntu in proot ---
echo ""
echo "[5/6] Installing Ubuntu via proot-distro..."
if proot-distro list --installed 2>/dev/null | grep -q ubuntu; then
  echo "  Ubuntu already installed, skipping."
else
  proot-distro install ubuntu
fi

# --- Step 6: Bootstrap inside proot ---
echo ""
echo "[6/6] Bootstrapping inside proot Ubuntu..."

proot-distro login ubuntu -- bash -c 'bash -s' <<'INNER_SCRIPT'
set -e

echo ""
echo "=== Inside proot Ubuntu ==="
echo ""

# --- Ensure Termux commands are accessible ---
TERMUX_BIN="/data/data/com.termux/files/usr/bin"
if [ -d "$TERMUX_BIN" ] && ! echo "$PATH" | grep -q "$TERMUX_BIN"; then
  export PATH="$PATH:$TERMUX_BIN"
fi
if [ -d "$TERMUX_BIN" ] && ! grep -q "$TERMUX_BIN" /etc/environment 2>/dev/null; then
  sed -i "s|^PATH=\(.*\)|PATH=\1:$TERMUX_BIN|" /etc/environment
  echo "Added Termux bin to /etc/environment PATH"
fi

# --- Install nvm ---
echo "[proot 1/5] Installing nvm..."
if [ -d "$HOME/.nvm" ]; then
  echo "  nvm already installed, skipping."
else
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# --- Install Node ---
echo ""
echo "[proot 2/5] Installing Node.js (latest LTS)..."
if command -v node &>/dev/null; then
  echo "  Node $(node --version) already installed, skipping."
else
  nvm install --lts
fi

# --- Install Claude Code ---
echo ""
echo "[proot 3/5] Installing Claude Code..."
if command -v claude &>/dev/null; then
  echo "  Claude Code already installed, skipping."
else
  npm install -g @anthropic-ai/claude-code
fi

# --- Claude Code login (interactive) ---
echo ""
if [ -e /dev/tty ]; then
  echo "============================================"
  echo "[proot 3.5/5] Claude Code login required."
  echo "  This will open a browser or give you a URL."
  echo "============================================"
  echo ""
  claude login </dev/tty
  echo ""
  echo "Claude Code login complete!"
else
  echo "[proot 3.5/5] Skipping Claude Code login (no TTY)."
  echo "  Run manually: proot-distro login ubuntu"
  echo "  Then: claude login"
fi

# --- Install Happy Coder ---
echo ""
echo "[proot 4/5] Installing Happy Coder..."
if command -v happy &>/dev/null; then
  echo "  Happy Coder already installed, skipping."
else
  npm install -g happy
fi

# --- Happy Coder login (interactive) ---
echo ""
if [ -e /dev/tty ]; then
  echo "============================================"
  echo "[proot 5/5] Happy Coder login required."
  echo "  This will authenticate via Claude Code."
  echo "============================================"
  echo ""
  happy auth login </dev/tty
  echo ""
  echo "Happy Coder login complete!"
else
  echo "[proot 5/5] Skipping Happy Coder login (no TTY)."
  echo "  Run manually: happy auth login"
fi

# --- Add happy daemon auto-start to .profile ---
# .bashrc has an early `[ -z "$PS1" ] && return` that skips everything
# below it in non-interactive shells. Use .profile instead, which runs
# for login shells and sources .bashrc (which loads nvm) when interactive.
if ! grep -q 'happy daemon' ~/.profile 2>/dev/null; then
  cat >> ~/.profile <<'PROFILE'

# Load nvm for non-interactive contexts
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Auto-start Happy Coder daemon
if command -v happy &>/dev/null && ! happy daemon status 2>/dev/null | grep -q "Daemon is running"; then
  happy daemon start &>/dev/null &
fi
PROFILE
  echo "Added happy daemon auto-start to .profile"
fi

echo ""
echo "============================================"
echo "  Setup complete!"
echo ""
echo "  To start: proot-distro login ubuntu"
echo "  Then run:  happy"
echo "============================================"

INNER_SCRIPT
