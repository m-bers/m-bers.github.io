export PATH="$BUN_INSTALL/bin:$PATH"

# Kill old processes
for port in 3005 8080; do
  PID=$(lsof -ti:$port 2>/dev/null)
  [ -n "$PID" ] && kill $PID 2>/dev/null
done
sleep 1

# Start PostgreSQL
PG_VERSION=$(ls /usr/lib/postgresql/ 2>/dev/null | head -1)
PG_DATA="/var/lib/postgresql/$PG_VERSION/main"
su - postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/pg_ctl -D $PG_DATA -l $PG_DATA/logfile start" 2>/dev/null || true
sleep 2

# Start gateway
export NODE_ENV=development
export DATABASE_URL="postgresql://postgres@localhost:5432/mobvibe"
export BETTER_AUTH_SECRET="$(cat /opt/mobvibe/.auth-secret 2>/dev/null)"
export SKIP_EMAIL_VERIFICATION=true
export PORT=3005
export GATEWAY_CORS_ORIGINS="http://localhost:8080"

cd /opt/mobvibe/gateway/apps/gateway
npx drizzle-kit migrate 2>/dev/null
node dist/index.js &

# Start HTTP proxy
node /opt/mobvibe/proxy.js &

# Start CLI daemon
cd /opt/mobvibe/cli
MOBVIBE_GATEWAY_URL=http://localhost:3005 bun apps/mobvibe-cli/dist/index.js start &>/dev/null &

echo "Mobvibe running:"
echo "  WebUI:   http://localhost:8080"
echo "  Gateway: http://localhost:3005"
STARTSH
