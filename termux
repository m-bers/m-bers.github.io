  curl -fsSL "$CLI_URL" | tar xz -C "$MOBVIBE_DIR/cli"

  echo "  Installing gateway dependencies..."
  cd "$MOBVIBE_DIR/gateway"
  pnpm install --frozen-lockfile 2>/dev/null || pnpm install

