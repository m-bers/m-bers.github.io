# Login CLI via expect
expect -c "
spawn env MOBVIBE_GATEWAY_URL=http://localhost:3005 bun /opt/mobvibe/cli/apps/mobvibe-cli/dist/index.js login
expect \"Email:\"
send \"admin@mobvibe.local\r\"
expect \"Password:\"
send \"admin123\r\"
expect eof
" 2>/dev/null

# Get E2EE secret and create auto-login page
E2EE_SECRET=$(cat ~/.mobvibe/credentials.json 2>/dev/null | grep masterSecret | sed 's/.*"masterSecret": *"\([^"]*\)".*/\1/')
cat > "$MOBVIBE_DIR/webui/auto-login.html" <<AUTOLOGIN
<!DOCTYPE html>
<html>
<head><title>Logging in...</title></head>
<body>
<p>Logging in...</p>
<script>
(async () => {
  try {
    localStorage.setItem("mobvibe_e2ee_master_secret", "$E2EE_SECRET");
    const res = await fetch("/api/auth/sign-in/email", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      credentials: "include",
      body: JSON.stringify({email: "admin@mobvibe.local", password: "admin123"})
    });
