#!/data/data/com.termux/files/usr/bin/bash
set -e

GITHUB_USER="m-bers"
GITHUB_REPO="m-bers/m-bers.github.io"
MOBVIBE_EMAIL="admin@mobvibe.local"
MOBVIBE_PASS="admin123"

echo "============================================"
echo "  Termux + Claude Code + Mobvibe Setup"
echo "============================================"
echo ""

# --- Step 1: Set mirror and update ---
echo "[1/7] Setting package mirror and updating..."
mkdir -p "$PREFIX/etc/apt"
echo "deb https://packages.termux.dev/apt/termux-main stable main" > "$PREFIX/etc/apt/sources.list"
pkg update -y
DEBIAN_FRONTEND=noninteractive pkg upgrade -y -o Dpkg::Options::="--force-confold"

# --- Step 2: Install core Termux packages ---
echo ""
echo "[2/7] Installing core Termux packages..."
pkg install -y proot-distro openssh android-tools termux-services

# --- Step 3: SSH setup with GitHub keys + runit supervision ---
echo ""
echo "[3/7] Setting up SSH with GitHub keys..."
mkdir -p ~/.ssh
chmod 700 ~/.ssh
echo "  Pulling SSH keys from github.com/$GITHUB_USER..."
curl -fsSL "https://github.com/$GITHUB_USER.keys" > ~/.ssh/authorized_keys
chmod 600 ~/.ssh/authorized_keys
NKEYS=$(wc -l < ~/.ssh/authorized_keys)
echo "  Imported $NKEYS key(s). Enabling sshd via termux-services (runit-supervised)..."

# Enable sshd so runit restarts it if it dies (termux-services requires SVDIR;
# normally set by the profile.d hook which only runs for login shells).
export SVDIR="$PREFIX/var/service"
sv-enable sshd 2>/dev/null || rm -f "$PREFIX/var/service/sshd/down"

# Kill any unsupervised sshd started by a previous install
pkill -x sshd 2>/dev/null || true

# Start runsvdir for this session if not already running
# (termux-services ships $PREFIX/etc/profile.d/start-services.sh which starts it
# automatically on each login shell — but we need it right now for this install.)
if ! pgrep -x runsvdir >/dev/null 2>&1; then
  nohup runsvdir -P "$PREFIX/var/service" </dev/null &>/dev/null &
  disown 2>/dev/null || true
  sleep 2
fi
echo "  sshd supervised — will auto-restart if killed."

# --- Step 4: Optional Termux integrations ---
echo ""
echo "[4/7] Checking optional Termux integrations..."

if pm list packages 2>/dev/null | grep -q 'com.termux.api'; then
  echo "  Termux:API app detected — installing termux-api package..."
  pkg install -y termux-api
else
  echo "  Termux:API app not installed, skipping."
fi

if pm list packages 2>/dev/null | grep -q 'com.termux.boot'; then
  echo "  Termux:Boot app detected — setting up boot scripts..."
  mkdir -p ~/.termux/boot
  # Single boot script that re-applies every setting that can drift across
  # reboots (wakelock, ADB reconnect, phantom-killer, sshd), then launches
  # Mobvibe inside proot.
  cat > ~/.termux/boot/start-all.sh <<'BOOT'
#!/data/data/com.termux/files/usr/bin/bash
PREFIX=/data/data/com.termux/files/usr
export PATH="$PREFIX/bin:$PATH"

# 1. Hold a wakelock so Termux isn't swept by Doze / low-memory killer.
termux-wake-lock

# 2. Start runit (sshd supervisor) if not already up.
# Boot scripts don't run as login shells, so start-services.sh isn't sourced.
if ! pgrep -x runsvdir >/dev/null 2>&1; then
  nohup runsvdir -P "$PREFIX/var/service" </dev/null &>/dev/null &
  disown 2>/dev/null || true
fi

# 3. Reconnect ADB if previously paired (pairing survives reboot; connection doesn't).
if [ -f "$HOME/.adb-connect-addr" ]; then
  adb connect "$(cat "$HOME/.adb-connect-addr")" &>/dev/null || true
  adb forward tcp:9222 localabstract:chrome_devtools_remote &>/dev/null || true
fi

# 4. Re-apply phantom-process killer disable. Idempotent; silently no-ops if
# adb isn't connected yet. These settings reset on OS update or sync, so
# reapplying every boot protects the proot session.
(
  adb shell /system/bin/device_config set_sync_disabled_for_tests persistent &>/dev/null || true
  adb shell /system/bin/device_config put activity_manager max_phantom_processes 2147483647 &>/dev/null || true
  adb shell settings put global settings_enable_monitor_phantom_procs false &>/dev/null || true
) &

# 5. Start Mobvibe inside proot via tmux (proot kills backgrounded children
# when its session exits, so tmux keeps the proot session alive).
tmux new-session -d -s mobvibe "proot-distro login ubuntu -- /bin/bash -lc 'source ~/.nvm/nvm.sh; export BUN_INSTALL=\$HOME/.bun; export PATH=\$BUN_INSTALL/bin:\$PATH; exec /opt/mobvibe/start.sh'" 2>/dev/null || true
BOOT
  chmod +x ~/.termux/boot/start-all.sh
  # Remove the old per-service boot script if upgrading from an older install
  rm -f ~/.termux/boot/start-mobvibe.sh
  echo "    Created unified boot script (wakelock + runit + adb + phantom killer + mobvibe)."
else
  echo "  Termux:Boot app not installed, skipping."
fi

if pm list packages 2>/dev/null | grep -q 'com.termux.widget'; then
  echo "  Termux:Widget app detected — creating shortcuts..."
  mkdir -p ~/.shortcuts
  cat > ~/.shortcuts/Claude.sh <<'WIDGET_CLAUDE'
#!/data/data/com.termux/files/usr/bin/bash
proot-distro login ubuntu -- /bin/bash -lc "claude"
WIDGET_CLAUDE
  chmod +x ~/.shortcuts/Claude.sh
  echo "    Created 'Claude' home screen shortcut."
else
  echo "  Termux:Widget app not installed, skipping."
fi

# --- Step 5: Storage access ---
echo ""
echo "[5/7] Setting up storage access..."
if [ -d ~/storage/shared ]; then
  echo "  Storage already configured, skipping."
else
