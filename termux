fi

# --- Install expect and supervisor ---
DEBIAN_FRONTEND=noninteractive apt-get install -y -qq expect supervisor >/dev/null 2>&1

# --- Download and install Mobvibe ---
echo ""
echo "[proot 6/9] Installing Mobvibe..."
MOBVIBE_DIR="/opt/mobvibe"
if [ -d "$MOBVIBE_DIR/gateway/apps" ] && [ -d "$MOBVIBE_DIR/cli/apps" ] && [ -f "$MOBVIBE_DIR/webui/index.html" ]; then
  echo "  Mobvibe already installed, skipping download."
else
  mkdir -p "$MOBVIBE_DIR"/{gateway,webui,cli}

  RELEASE_URLS=$(curl -fsSL "https://api.github.com/repos/m-bers/m-bers.github.io/releases/latest" | grep browser_download_url)
  GATEWAY_URL=$(echo "$RELEASE_URLS" | grep gateway | sed 's/.*"\(http[^"]*\)".*/\1/')
  WEBUI_URL=$(echo "$RELEASE_URLS" | grep webui | sed 's/.*"\(http[^"]*\)".*/\1/')
