  echo "  Downloading gateway..."
  curl -fsSL "$GATEWAY_URL" | tar xz -C "$MOBVIBE_DIR/gateway"

  echo "  Downloading WebUI..."
  curl -fsSL "$WEBUI_URL" | tar xz -C "$MOBVIBE_DIR/webui"

  echo "  Configuring WebUI gateway URL..."
  find "$MOBVIBE_DIR/webui" -name "*.js" -exec sed -i 's|__MOBVIBE_GATEWAY_URL__|http://localhost:8080|g' {} + 2>/dev/null

