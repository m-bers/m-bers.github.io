  if [ -d "$PW_PKG/skills/playwright-cli" ]; then
    mkdir -p "$HOME/.claude/skills"
    cp -r "$PW_PKG/skills/playwright-cli" "$HOME/.claude/skills/"
    echo "  Playwright skills installed."
  fi
fi

# --- Claude Code login (interactive) ---
echo ""
if [ -e /dev/tty ]; then
  echo "============================================"
  echo "[proot 3.5/9] Claude Code login required."
  echo "  This will open a browser or give you a URL."
  echo "============================================"
  echo ""
  claude auth login </dev/tty
  echo ""
  echo "Claude Code login complete!"
