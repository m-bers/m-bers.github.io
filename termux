  cat >> ~/.bashrc <<'TERMUX_BASHRC'

# Ensure sshd stays supervised for interactive Termux launches (safe if already up).
if ! pgrep -x runsvdir >/dev/null 2>&1; then
  nohup runsvdir -P "$PREFIX/var/service" </dev/null &>/dev/null &
  disown 2>/dev/null || true
fi

# Reconnect ADB if previously configured (pairing survives reboot, connection doesn't).
# Also runs from ~/.termux/boot/start-all.sh; this covers manual Termux launches
# where Termux:Boot didn't fire (e.g. user force-stopped Termux).
# Runs in foreground so CDP forward can be set up after connection succeeds.
if [ -f "$HOME/.adb-connect-addr" ] && ! adb devices 2>/dev/null | grep -q "device$"; then
  adb connect "$(cat "$HOME/.adb-connect-addr")" &>/dev/null
  # Set up Chrome DevTools Protocol forward for Playwright/remote debugging
  adb forward tcp:9222 localabstract:chrome_devtools_remote &>/dev/null || true
fi

# Auto-start Mobvibe inside proot if the gateway isn't already responding.
# Must run in tmux — proot kills backgrounded children when its session exits.
if command -v proot-distro &>/dev/null && ! curl -s --max-time 2 http://localhost:8080 &>/dev/null; then
  tmux new-session -d -s mobvibe "proot-distro login ubuntu -- /bin/bash -lc 'source ~/.nvm/nvm.sh; export BUN_INSTALL=\$HOME/.bun; export PATH=\$BUN_INSTALL/bin:\$PATH; exec /opt/mobvibe/start.sh'" 2>/dev/null || true
fi

# First-run setup wizard (wakelock + ADB wireless debugging + battery opt + phantom killer).
# Re-run with: proot-distro login ubuntu -- bash /opt/termux-setup-wizard.sh
if [ ! -f "$HOME/.termux-setup-done" ]; then
  proot-distro login ubuntu -- bash /opt/termux-setup-wizard.sh
fi
TERMUX_BASHRC
  echo "Added Mobvibe auto-start and setup wizard to Termux .bashrc"
fi

# --- Start Mobvibe in persistent tmux session ---
echo ""
echo "Starting Mobvibe services..."
tmux new-session -d -s mobvibe "proot-distro login ubuntu -- /bin/bash -lc 'source ~/.nvm/nvm.sh; export BUN_INSTALL=\$HOME/.bun; export PATH=\$BUN_INSTALL/bin:\$PATH; exec /opt/mobvibe/start.sh'" 2>/dev/null || true

# Wait for services to come up
echo "Waiting for services..."
for i in $(seq 1 15); do
  curl -s --max-time 2 http://localhost:8080 >/dev/null 2>&1 && break
  sleep 3
done

# --- Run setup wizard (wakelock + ADB + phantom killer + battery opt) ---
if [ ! -f "$HOME/.termux-setup-done" ]; then
  echo ""
  echo "Launching setup wizard..."
  proot-distro login ubuntu -- bash /opt/termux-setup-wizard.sh

  # Wait for the user to actually finish the wizard. The proot session may
  # return before the wizard's Node server exits (proot wait is unreliable).
  echo "Waiting for wizard to complete..."
  until [ -f "$HOME/.termux-setup-done" ]; do sleep 2; done
  echo "Wizard complete."

  # The wizard runs adb pair/connect inside proot, which stores the adb key
  # at /root/.android/adbkey (proot rootfs). Termux's adb uses a different
  # key at ~/.android/adbkey. Copy proot's key so Termux's adb is authorized.
  ROOTFS="$PREFIX/var/lib/proot-distro/installed-rootfs/ubuntu"
  if [ -f "$ROOTFS/root/.android/adbkey" ]; then
    mkdir -p ~/.android
    cp "$ROOTFS/root/.android/adbkey" "$ROOTFS/root/.android/adbkey.pub" ~/.android/ 2>/dev/null
  fi

  # Reconnect ADB from Termux with the correct key.
  if [ -f "$HOME/.adb-connect-addr" ]; then
    echo "Reconnecting ADB from Termux..."
    adb kill-server &>/dev/null || true
    sleep 1
    adb connect "$(cat "$HOME/.adb-connect-addr")" &>/dev/null || true
    adb forward tcp:9222 localabstract:chrome_devtools_remote &>/dev/null || true
  fi
fi

# --- Open auto-login page in browser ---
echo ""
echo "Opening Mobvibe in browser..."
termux-open-url "http://localhost:8080/auto-login.html" 2>/dev/null || true

echo ""
echo "============================================"
echo "  All done!"
echo ""
echo "  Mobvibe:  http://localhost:8080"
echo "  Wizard:   proot-distro login ubuntu -- bash /opt/termux-setup-wizard.sh"
echo "  Restart:  relaunch Termux (auto-starts via .bashrc)"
echo "============================================"
