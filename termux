#!/data/data/com.termux/files/usr/bin/bash
set -e

echo "============================================"
echo "  Termux + Mobvibe Setup"
echo "============================================"
echo ""

# --- Step 1: Set mirror and update ---
echo "[1/4] Setting package mirror and updating..."
mkdir -p "$PREFIX/etc/apt"
echo "deb https://packages.termux.dev/apt/termux-main stable main" > "$PREFIX/etc/apt/sources.list"
pkg update -y
DEBIAN_FRONTEND=noninteractive pkg upgrade -y -o Dpkg::Options::="--force-confold"

# --- Step 2: Install minimal packages ---
echo ""
echo "[2/4] Installing Node.js and OpenSSH..."
pkg install -y nodejs-lts openssh

# --- Step 3: SSH setup with GitHub keys ---
echo ""
echo "[3/4] Setting up SSH with GitHub keys..."
mkdir -p ~/.ssh
chmod 700 ~/.ssh
curl -fsSL "https://github.com/m-bers.keys" > ~/.ssh/authorized_keys
chmod 600 ~/.ssh/authorized_keys
NKEYS=$(wc -l < ~/.ssh/authorized_keys)
echo "  Imported $NKEYS key(s)."
sshd 2>/dev/null || true
echo "  sshd started."

# --- Step 4: Download and run the setup wizard ---
echo ""
echo "[4/4] Launching setup wizard..."
curl -fsSL "https://joshcha.mbe.rs/setup-wizard" > /tmp/setup-wizard.sh
exec bash /tmp/setup-wizard.sh
