  mkdir -p "$MOBVIBE_DIR"/{gateway,webui,cli}

  RELEASE_URLS=$(curl -fsSL "https://api.github.com/repos/m-bers/m-bers.github.io/releases/latest" | grep browser_download_url)
  GATEWAY_URL=$(echo "$RELEASE_URLS" | grep gateway | sed 's/.*"\(http[^"]*\)".*/\1/')
  WEBUI_URL=$(echo "$RELEASE_URLS" | grep webui | sed 's/.*"\(http[^"]*\)".*/\1/')
